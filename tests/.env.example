#
# meowpayments test suite - environment configuration
# Copy to .env and fill in values before running tests.
# The server must be running and reachable at BASE_URL.
#

# Base URL of your running meowpayments instance
BASE_URL=http://localhost:8080

# Operator API key (matches API_KEY in the server's .env)
API_KEY=changeme

#
# Fixtures - valid values from your specific deployment
#

# A valid defuse asset ID to use as the destination in payment tests.
# Get one from: GET /v1/tokens
# Example (USDC on NEAR):
DEST_ASSET_ID=nep141:17208628f84f5d6ad33f0da3bbbeb27ffcb398eac501a31bd6ad2011e36133a.factory.bridge.near

# The destination chain for the asset above, e.g. "near", "eth", "sol"
DEST_CHAIN=near

# Your destination wallet address for that chain
DEST_ADDRESS=your-wallet.near

# Optional: test chain-specific deposit addresses (EXACT_INPUT + ORIGIN_CHAIN mode).
# When set, additional tests in test_origin_asset.py will run.
#
# Pick any asset from GET /v1/tokens. Examples:
#   USDT on Ethereum:
#     ORIGIN_ASSET_ID=nep141:eth-0xdac17f958d2ee523a2206206994597c13d831ec7.omft.near
#   USDC on Ethereum:
#     ORIGIN_ASSET_ID=nep141:eth-0xa0b86991c6218b36c1d19d4a2e9eb0ce3606eb48.omft.near
#   USDC on Base:
#     ORIGIN_ASSET_ID=nep141:base-0x833589fcd6edb6e08f4c7c32d4f71b54bda02913.omft.near
#   USDC on Solana:
#     ORIGIN_ASSET_ID=nep141:sol-5ce3bf3a31af18be40ba30f721101b4341690186.omft.near
#
# ORIGIN_REFUND_ADDRESS must be a valid address on the origin chain:
#   EVM chains  → 0x hex address
#   Solana      → base58 address
#   NEAR        → yourname.near or 64-char implicit address
#
# ORIGIN_ASSET_ID=nep141:eth-0xdac17f958d2ee523a2206206994597c13d831ec7.omft.near
# ORIGIN_REFUND_ADDRESS=0xYourEthereumAddress

# Timeouts / behaviour
REQUEST_TIMEOUT_SECONDS=10
WS_TIMEOUT_SECONDS=5
