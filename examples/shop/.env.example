# URL of your running meowpayments instance
meowpayments_BASE_URL=http://localhost:3434

# API key set in your meowpayments config (API_KEY env var)
meowpayments_API_KEY=your-api-key-here

# On-chain address to receive swapped tokens
DEST_ADDRESS=yourwalletaddress.near

# Chain and asset to receive (must match GET /v1/tokens output)
DEST_CHAIN=near
DEST_ASSET_ID=nep141:usdc.near

# Public URL of this shop server (used for callback_url)
SHOP_BASE_URL=http://localhost:8000

# Must match WORKER_WEBHOOK_SECRET in your meowpayments .env
WEBHOOK_SECRET=changeme_generate_with_openssl_rand_hex_32
