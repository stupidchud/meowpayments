#
# Copy to .env and fill in values
#

#
# HTTP server
#
HTTP_ADDR=:3434
# The public URL of your deployment - used to build payment_url links.
HTTP_BASE_URL=https://pay.example.com
# CORS allowed origins. Use "*" for open access or a comma-separated list.
HTTP_ALLOWED_ORIGINS=*

#
# Database
#
DATABASE_URL=postgres://meowpayments:secret@localhost:5432/meowpayments?sslmode=disable
DB_MAX_CONNS=20
DB_MIN_CONNS=2
# Path to migrations directory. Default works when running from project root.
DB_MIGRATIONS_DIR=./internal/store/migrations

#
# Operator authentication
# Generate with: openssl rand -hex 32
# Used for all /v1/payments/* endpoints and the operator WebSocket.
#
API_KEY=changeme_generate_with_openssl_rand_hex_32

#
# NEAR Intents 1-click API
# Get your API key at https://partners.near-intents.org/home
# Without an API key, the 1-click API adds a 0.2% platform fee.
#
ONECLICK_BASE_URL=https://1click.chaindefuser.com
ONECLICK_API_KEY=your_1click_jwt_token_here
ONECLICK_TIMEOUT=30s
ONECLICK_TOKEN_CACHE_TTL=5m
# Default slippage tolerance in basis points. 100 = 1%.
ONECLICK_DEFAULT_SLIPPAGE=100
# Address where failed/refunded swap funds are sent.
# Configure a NEAR account or EVM address you control.
ONECLICK_REFUND_ADDRESS=your-refund.near

#
# Background workers
#
# How often to poll active payments for status updates.
POLLER_FAST_INTERVAL=10s
POLLER_SLOW_INTERVAL=30s
POLLER_MAX_FAILURES=10

WORKER_CALLBACK_WORKERS=5
WORKER_CALLBACK_MAX_RETRIES=5
WORKER_CALLBACK_TIMEOUT=10s
# Secret used to sign HMAC-SHA256 callback payloads.
# Generate with: openssl rand -hex 32
WORKER_WEBHOOK_SECRET=changeme_generate_with_openssl_rand_hex_32
